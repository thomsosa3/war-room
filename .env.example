# Copy this file to ".env" and fill in your values.
# These are bundled into the app at build time (Vite inlines VITE_* vars).
#
# For a private 2-person tool this is acceptable (private-by-obscurity).
# To lock it down later, enable Supabase Row Level Security — see README.

# From Supabase: Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Shared passphrase entered at app launch (checked client-side).
# Both copies must use the same value.
VITE_SHARED_PASSPHRASE=summer2026
